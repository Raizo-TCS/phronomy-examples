<%# frozen_string_literal: true %>
<div class="flex flex-col h-full bg-gray-100">

  <%# Header %>
  <header class="bg-white border-b border-gray-200 px-4 py-3 shadow-sm">
    <div class="flex items-center justify-between flex-wrap gap-2">
      <h1 class="text-lg font-semibold text-gray-800">Secure Chat</h1>

      <%# Security status badges %>
      <div class="flex items-center gap-2 text-xs">
        <span class="bg-green-100 text-green-700 px-2 py-1 rounded-full font-medium">Guardrails: ON</span>
        <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded-full font-medium">Encryption: ON</span>
        <span class="bg-amber-100 text-amber-700 px-2 py-1 rounded-full font-medium">TTL: <%= PHRONOMY_MEMORY_TTL %>s</span>
      </div>

      <%# User / thread info + actions %>
      <div class="flex items-center gap-2 flex-wrap">
        <% if @user_id %>
          <span class="text-xs text-gray-400 font-mono">user: <%= @user_id.split("-").first %></span>
        <% end %>
        <% if @thread_id %>
          <span class="text-xs text-gray-400 font-mono">thread: <%= @thread_id.split("-").first %>…</span>
          <%= button_to "Delete Chat", conversation_path(@thread_id), method: :delete,
                data: { confirm: "Permanently delete this conversation?" },
                class: "text-xs bg-red-100 hover:bg-red-200 text-red-700 px-3 py-1 rounded-lg transition" %>
        <% end %>
        <%= button_to "New Chat", new_conversation_path, method: :post,
              class: "text-sm bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-1.5 rounded-lg transition" %>
      </div>
    </div>
  </header>

  <%# Message list %>
  <main id="messages" class="flex-1 overflow-y-auto px-4 py-6 space-y-4">
    <% if @messages.empty? %>
      <p class="text-center text-gray-400 mt-20 text-sm">
        <% if @thread_id %>
          No messages yet. Say something!
        <% else %>
          Click <strong>New Chat</strong> to start a conversation.
        <% end %>
      </p>
    <% end %>

    <% @messages.each do |msg| %>
      <% if msg.role == "user" %>
        <div class="flex justify-end">
          <div class="bg-indigo-600 text-white rounded-2xl rounded-tr-sm px-4 py-2 max-w-xl text-sm whitespace-pre-wrap"><%= msg.content %></div>
        </div>
      <% elsif msg.role == "assistant" && msg.content.present? %>
        <div class="flex justify-start">
          <div class="bg-white border border-gray-200 rounded-2xl rounded-tl-sm px-4 py-2 max-w-xl text-sm whitespace-pre-wrap text-gray-800"><%= msg.content %></div>
        </div>
      <% end %>
    <% end %>

    <%# Thinking indicator %>
    <div id="thinking" class="flex justify-start hidden">
      <div class="bg-white border border-gray-200 rounded-2xl rounded-tl-sm px-4 py-2 text-sm text-gray-400 italic">Thinking…</div>
    </div>

    <%# Summary output area %>
    <div id="summary-box" class="hidden">
      <div class="bg-yellow-50 border border-yellow-200 rounded-xl px-4 py-3 text-sm text-gray-700">
        <p class="font-semibold text-yellow-700 mb-1">📋 Conversation Summary (encrypted checkpoint stored)</p>
        <p id="summary-text"></p>
      </div>
    </div>

    <%# Error area %>
    <div id="error-msg" class="hidden text-center text-sm text-red-500"></div>
  </main>

  <%# Input form %>
  <footer class="bg-white border-t border-gray-200 px-4 py-3">
    <% if @thread_id %>
      <form id="chat-form" class="flex gap-2 mb-2">
        <input id="chat-input" type="text" name="content" placeholder="Type a message… (PII and injection attempts will be blocked)"
               autocomplete="off"
               class="flex-1 border border-gray-300 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
        <button type="submit"
                class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2 rounded-xl text-sm transition">
          Send
        </button>
      </form>
      <div class="flex justify-end">
        <button id="summarize-btn"
                class="text-xs text-gray-500 hover:text-indigo-600 underline">
          Summarize conversation (Feature C demo)
        </button>
      </div>
    <% else %>
      <p class="text-center text-sm text-gray-400">Start a new chat to begin.</p>
    <% end %>
  </footer>
</div>

<script>
(function () {
  const form        = document.getElementById("chat-form");
  const input       = document.getElementById("chat-input");
  const messages    = document.getElementById("messages");
  const thinking    = document.getElementById("thinking");
  const errorMsg    = document.getElementById("error-msg");
  const summaryBox  = document.getElementById("summary-box");
  const summaryText = document.getElementById("summary-text");
  const summarizeBtn= document.getElementById("summarize-btn");
  const csrfToken   = document.querySelector('meta[name="csrf-token"]').content;

  function appendBubble(role, text) {
    const wrapper = document.createElement("div");
    wrapper.className = role === "user" ? "flex justify-end" : "flex justify-start";
    const bubble = document.createElement("div");
    bubble.className = role === "user"
      ? "bg-indigo-600 text-white rounded-2xl rounded-tr-sm px-4 py-2 max-w-xl text-sm whitespace-pre-wrap"
      : "bg-white border border-gray-200 rounded-2xl rounded-tl-sm px-4 py-2 max-w-xl text-sm whitespace-pre-wrap text-gray-800";
    bubble.textContent = text;
    wrapper.appendChild(bubble);
    thinking.before(wrapper);
    messages.scrollTop = messages.scrollHeight;
  }

  function showError(msg) {
    errorMsg.textContent = msg;
    errorMsg.classList.remove("hidden");
    setTimeout(() => errorMsg.classList.add("hidden"), 5000);
  }

  if (form) {
    form.addEventListener("submit", async function (e) {
      e.preventDefault();
      const content = input.value.trim();
      if (!content) return;

      input.value = "";
      summaryBox.classList.add("hidden");
      errorMsg.classList.add("hidden");
      appendBubble("user", content);
      thinking.classList.remove("hidden");
      messages.scrollTop = messages.scrollHeight;

      try {
        const res = await fetch("<%= messages_path %>", {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded", "X-CSRF-Token": csrfToken },
          body: new URLSearchParams({ content })
        });
        const data = await res.json();
        thinking.classList.add("hidden");
        if (data.reply) {
          appendBubble("assistant", data.reply);
        } else {
          showError(data.error || "An error occurred.");
        }
      } catch (err) {
        thinking.classList.add("hidden");
        showError("Network error. Please try again.");
      }
    });
  }

  if (summarizeBtn) {
    summarizeBtn.addEventListener("click", async function () {
      summaryBox.classList.add("hidden");
      errorMsg.classList.add("hidden");
      summarizeBtn.textContent = "Summarizing…";
      summarizeBtn.disabled = true;

      try {
        const res = await fetch("<%= summaries_path %>", {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded", "X-CSRF-Token": csrfToken }
        });
        const data = await res.json();
        if (data.summary) {
          summaryText.textContent = data.summary;
          summaryBox.classList.remove("hidden");
          messages.scrollTop = messages.scrollHeight;
        } else {
          showError(data.error || "Summarization failed.");
        }
      } catch (err) {
        showError("Network error during summarization.");
      } finally {
        summarizeBtn.textContent = "Summarize conversation (Feature C demo)";
        summarizeBtn.disabled = false;
      }
    });
  }

  if (messages) messages.scrollTop = messages.scrollHeight;
})();
</script>
