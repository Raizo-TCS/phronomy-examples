<%# app/views/scans/index.html.erb — CVE Scanner Web UI %>
<style>
  body { font-family: sans-serif; max-width: 900px; margin: 2rem auto; padding: 0 1rem; color: #222; }
  h1 { font-size: 1.5rem; margin-bottom: 0.25rem; }
  .subtitle { color: #666; margin-bottom: 1.5rem; font-size: 0.9rem; }
  .card { border: 1px solid #ddd; border-radius: 6px; padding: 1rem; margin-bottom: 1rem; background: #fafafa; }
  .card h3 { margin: 0 0 0.5rem; font-size: 1rem; color: #444; }
  label { display: block; margin-bottom: 0.4rem; font-weight: 500; }
  textarea { width: 100%; padding: 0.5rem; font-size: 0.95rem; border: 1px solid #ccc; border-radius: 4px; resize: vertical; box-sizing: border-box; }
  .btn { padding: 0.5rem 1.2rem; border: none; border-radius: 4px; cursor: pointer; font-size: 0.95rem; }
  .btn-primary { background: #1a73e8; color: #fff; }
  .btn-primary:disabled { background: #aaa; }
  .btn-approve { background: #34a853; color: #fff; }
  .btn-skip    { background: #ea4335; color: #fff; }
  .approval-box { background: #fff8e1; border: 1px solid #f9c74f; border-radius: 6px; padding: 1rem; margin-bottom: 1rem; }
  .approval-box h3 { margin: 0 0 0.5rem; color: #7a5900; }
  .cmd-item { display: flex; align-items: flex-start; gap: 0.5rem; margin-bottom: 0.3rem; }
  .cmd-item label { font-family: monospace; font-size: 0.85rem; font-weight: normal; margin: 0; }
  .result-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  .result-table th, .result-table td { border: 1px solid #ddd; padding: 0.4rem 0.6rem; text-align: left; vertical-align: top; }
  .result-table th { background: #f0f0f0; }
  .vulnerable    { color: #c0392b; font-weight: bold; }
  .not_vulnerable { color: #27ae60; }
  .remediated    { color: #2980b9; }
  .unknown       { color: #888; }
  .detail-desc   { color: #555; font-size: 0.82rem; margin-top: 0.2rem; }
  .detail-pkg    { color: #666; font-size: 0.8rem; font-family: monospace; }
  .detail-reason { color: #333; font-size: 0.85rem; margin-top: 0.3rem; font-style: italic; }
  #status-line   { font-size: 0.85rem; color: #888; margin-top: 0.3rem; }
  /* ── Chat log styles ── */
  #chat-log { display: flex; flex-direction: column; gap: 0.6rem; max-height: 520px; overflow-y: auto; padding: 0.25rem 0; }
  .chat-msg { display: flex; flex-direction: column; max-width: 90%; }
  .chat-msg.llm.wide { max-width: 100%; }
  .chat-msg.agent  { align-self: flex-end; }
  .chat-msg.llm    { align-self: flex-start; }
  .chat-msg.system { align-self: center; max-width: 100%; }
  .chat-bubble { padding: 0.5rem 0.75rem; border-radius: 12px; font-size: 0.85rem; line-height: 1.5; white-space: pre-wrap; word-break: break-word; }
  .chat-msg.agent  .chat-bubble { background: #e8f0fe; color: #1a1a2e; border-bottom-right-radius: 3px; }
  .chat-msg.llm    .chat-bubble { background: #f0f7f0; color: #1a2e1a; border-bottom-left-radius: 3px; }
  .chat-msg.system .chat-bubble { background: #f5f5f5; color: #555; font-size: 0.8rem; text-align: center; border-radius: 6px; width: 100%; }
  .chat-label { font-size: 0.72rem; color: #888; margin-bottom: 0.15rem; }
  .chat-msg.agent .chat-label { text-align: right; }
  .chat-msg.llm   .chat-label { text-align: left; }
  .chat-cursor::after { content: "▋"; animation: blink 0.8s step-end infinite; color: #666; }
  @keyframes blink { 50% { opacity: 0; } }
  /* user-note input */
  .user-note-area { margin-top: 0.8rem; border-top: 1px solid #f0d97a; padding-top: 0.6rem; }
  .user-note-area label { font-size: 0.82rem; color: #7a5900; margin-bottom: 0.3rem; }
  .user-note-area textarea { width: 100%; padding: 0.4rem; font-size: 0.82rem; border: 1px solid #e0c060; border-radius: 4px; resize: vertical; box-sizing: border-box; background: #fffdf0; }
  .user-note-area .send-note-row { display: flex; justify-content: flex-end; margin-top: 0.3rem; }
  /* inline approval card inside chat log */
  .approval-inline-card { width: 100%; }
  .approval-inline-card .approval-box { margin: 0; }
  /* persistent chat input bar */
  #chat-input-bar { display: none; border-top: 1px solid #ddd; padding-top: 0.6rem; margin-top: 0.4rem; }
  .chat-input-row { display: flex; gap: 0.5rem; align-items: flex-end; }
  .chat-input-row textarea { flex: 1; padding: 0.4rem 0.6rem; font-size: 0.85rem; border: 1px solid #ccc; border-radius: 6px; resize: none; }
  .btn-send { background: #1a73e8; color: #fff; padding: 0.45rem 1rem; border: none; border-radius: 6px; cursor: pointer; font-size: 0.85rem; white-space: nowrap; }
  .btn-send:disabled { background: #aaa; }
</style>

<h1>CVE Scanner</h1>
<p class="subtitle">Agent pipeline for investigating and remediating package vulnerabilities on Ubuntu</p>

<%# ── 入力フォーム ── %>
<div class="card" id="input-card">
  <h3>Enter CVE IDs</h3>
  <label for="cve-input">CVE ID(s) — space or comma separated</label>
  <textarea id="cve-input" rows="3" placeholder="e.g. CVE-2024-1234, CVE-2023-52160"></textarea>
  <div style="margin-top:0.6rem">
    <button class="btn btn-primary" id="scan-btn" onclick="startScan()">Start Scan</button>
  </div>
  <p id="status-line"></p>
</div>



<%# ── Pipeline (会話ログ) ── %>
<div class="card" id="log-card" style="display:none">
  <h3>Pipeline Log</h3>
  <div id="chat-log"></div>
  <%# Persistent message bar — always available while scan is active %>
  <div id="chat-input-bar">
    <div class="chat-input-row">
      <textarea id="chat-bar-input" rows="2" placeholder="Ask a question, give context, or send instructions to the AI (applied to the next round)"></textarea>
      <button class="btn btn-send" id="chat-bar-send" onclick="sendStandaloneNote()">Send</button>
    </div>
  </div>
</div>

<script>
let currentScanId = null;
window.ws = null;
let activeLlmBubble = null; // currently streaming LLM bubble element
let awaitingFollowup = false; // true when graph is halted before :handle_followup
let chatTurnActive = false; // true between chat_turn_start and chat_turn_done

function startScan() {
  const raw = document.getElementById("cve-input").value.trim();
  if (!raw) { alert("Please enter at least one CVE ID."); return; }

  document.getElementById("scan-btn").disabled = true;
  document.getElementById("status-line").textContent = "Submitting...";
  document.getElementById("log-card").style.display  = "block";
  document.getElementById("chat-log").innerHTML       = "";
  document.getElementById("chat-input-bar").style.display = "none";
  awaitingFollowup = false;
  chatTurnActive = false;
  // Remove any previous inline results table from the pipeline log.
  const prevResults = document.getElementById("inline-results");
  if (prevResults) prevResults.parentElement.remove();
  activeLlmBubble = null;

  fetch("/scans", {
    method: "POST",
    headers: {
      "Content-Type": "application/x-www-form-urlencoded",
      "X-CSRF-Token": document.querySelector("meta[name='csrf-token']")?.content || ""
    },
    body: new URLSearchParams({ cve_ids: raw })
  })
  .then(r => r.json())
  .then(data => {
    currentScanId = data.scan_id;
    document.getElementById("status-line").textContent = `Scan ID: ${currentScanId}`;
    connectWebSocket(currentScanId);
  });
}

function connectWebSocket(scanId) {
  window.ws = new WebSocket(
    `${location.protocol === "https:" ? "wss" : "ws"}://${location.host}/cable`
  );

  ws.addEventListener("open", () => {
    ws.send(JSON.stringify({
      command: "subscribe",
      identifier: JSON.stringify({ channel: "ScanChannel", scan_id: scanId })
    }));
  });

  ws.addEventListener("message", (event) => {
    const envelope = JSON.parse(event.data);
    if (!envelope.message) return;
    handleMessage(envelope.message);
  });
}

// ── Chat helpers ─────────────────────────────────────────────────────────────

function addChatBubble(side, label, text, opts = {}) {
  const log = document.getElementById("chat-log");
  const wrap = document.createElement("div");
  wrap.className = `chat-msg ${side}`;

  const lbl = document.createElement("div");
  lbl.className = "chat-label";
  lbl.textContent = label;

  const bubble = document.createElement("div");
  bubble.className = "chat-bubble" + (opts.cursor ? " chat-cursor" : "");
  bubble.textContent = text;

  wrap.appendChild(lbl);
  wrap.appendChild(bubble);
  log.appendChild(wrap);
  log.scrollTop = log.scrollHeight;
  return bubble;
}

function addSystemLine(text) {
  addChatBubble("system", "", text);
}

// ── Message handler ───────────────────────────────────────────────────────────

function handleMessage(msg) {
  const statusEl = document.getElementById("status-line");

  if (msg.type === "user_note") {
    // Echo the user's own note back into the chat log (sent via standalone Send)
    addChatBubble("agent", "You", msg.content);
  }
  else if (msg.type === "status") {
    addSystemLine(msg.message);
    statusEl.textContent = msg.message;
  }
  else if (msg.type === "log") {
    // Pipeline log messages (node transitions, command runs, report lines).
    // If the LLM was mid-stream and a tool call starts, finalise the current
    // bubble so subsequent tokens open a new one after the tool logs.
    // Only subtype=="tool_call" triggers finalisation (not pipeline logs).
    if (msg.subtype === "tool_call" && activeLlmBubble) {
      activeLlmBubble.classList.remove("chat-cursor");
      activeLlmBubble = null;
    }
    addSystemLine(msg.message);
  }
  else if (msg.type === "agent_step") {
    // Ruby agent emitting a step description
    addChatBubble("agent", "Agent › " + msg.node, msg.message);
  }
  else if (msg.type === "chat_turn_start") {
    // Agent is about to call the LLM — show the prompt preview.
    // FollowupAgent has its own followup_answer bubble; suppress the context preview.
    if (msg.role === "FollowupAgent") return;
    // Finalise any leftover streaming bubble from a previous turn.
    if (activeLlmBubble) {
      activeLlmBubble.classList.remove("chat-cursor");
      activeLlmBubble = null;
    }    chatTurnActive = true;    addChatBubble("agent", "Agent › " + msg.role, "Sending context to LLM…\n" + msg.prompt_preview + (msg.prompt_preview.length >= 200 ? "…" : ""));
    // Do NOT pre-create the LLM bubble here. It will be created lazily when
    // the first llm_token arrives, ensuring it appears AFTER any tool-call
    // log messages rather than before them.
  }
  else if (msg.type === "llm_token") {
    // Streaming token from the LLM — skip empty tokens and stale tokens
    // that arrive after chat_turn_done (ActionCable delivery is not strictly
    // ordered with respect to chat_turn_done).
    // FollowupAgent output is raw JSON; suppress streaming and show only the
    // parsed followup_answer bubble instead.
    if (!msg.token || msg.role === "FollowupAgent" || !chatTurnActive) return;
    if (!activeLlmBubble) {
      activeLlmBubble = addChatBubble("llm", msg.role + " (streaming…)", "", {cursor: true});
    }
    activeLlmBubble.textContent += msg.token;
    const log = document.getElementById("chat-log");
    log.scrollTop = log.scrollHeight;
  }
  else if (msg.type === "chat_turn_done") {
    // LLM finished streaming — finalise the bubble.
    // For FollowupAgent, no streaming bubble was created; skip finalisation.
    if (msg.role === "FollowupAgent") { activeLlmBubble = null; chatTurnActive = false; return; }
    chatTurnActive = false;

    // Parse the content to detect intermediate routing decisions.
    // decision:"need_more" means the agent is about to call more tools — treat
    // this as an internal pipeline event (centre, like tool-call logs) rather
    // than a user-facing LLM response.
    // The LLM sometimes wraps JSON in markdown code fences (```json … ```)
    // or includes leading/trailing prose, so we try multiple extraction strategies.
    let parsed = null;
    try {
      let raw = (msg.content || "").trim();
      // Strip markdown code fences if present.
      raw = raw.replace(/^```(?:json)?\s*/i, "").replace(/\s*```\s*$/, "").trim();
      parsed = JSON.parse(raw);
    } catch (_) {
      // Fallback: extract the first {...} block from the content.
      const m = (msg.content || "").match(/\{[\s\S]*\}/);
      if (m) { try { parsed = JSON.parse(m[0]); } catch (_) {} }
    }
    // Both "need_more" and "done" are internal CveAnalyst routing decisions.
    // Treat them as pipeline log events (centre) rather than LLM bubbles.
    const isInternal = parsed && (parsed.decision === "need_more" || parsed.decision === "done");

    if (isInternal) {
      // Discard the streaming bubble (it was accumulating internal JSON tokens).
      if (activeLlmBubble) {
        activeLlmBubble.parentElement.remove();
        activeLlmBubble = null;
      }
      if (parsed.decision === "need_more") {
        // Intermediate routing decision — show as centre pipeline log.
        const cmds = (parsed.proposed_commands || []).join(", ");
        addSystemLine(`${msg.role} → need_more: proposing [${cmds}]`);
      } else {
        // decision === "done": render inline results table in the pipeline log.
        const cveDetails = {};
        Object.entries(parsed.reasoning || {}).forEach(([cve, r]) => {
          cveDetails[cve] = { reasoning: r };
        });
        addResultTableInline(parsed.vulnerability_status || {}, cveDetails);
      }
    } else {
      if (activeLlmBubble) {
        activeLlmBubble.classList.remove("chat-cursor");
        // Replace streaming tokens with the clean final output from the server.
        activeLlmBubble.textContent = msg.content || "";
        activeLlmBubble.parentElement.querySelector(".chat-label").textContent = msg.role + " (done)";
      } else {
        addChatBubble("llm", msg.role + " (done)", msg.content || "");
      }
      activeLlmBubble = null;
    }
  }
  else if (msg.type === "awaiting_approval") {
    addSystemLine(`⏸ Awaiting approval for ${msg.approval_type} commands (Round ${msg.round})`);
    renderApprovalBox(msg);
    document.getElementById("chat-input-bar").style.display = "block";
  }
  else if (msg.type === "done") {
    addSystemLine(`✓ Scan complete — ${msg.check_iterations} check round(s) / ${msg.remediation_iterations} remediation round(s)`);
    addResultTableInline(msg.vulnerability_status || {}, msg.cve_details || {});
    statusEl.textContent = `Done — ${msg.check_iterations} check round(s) / ${msg.remediation_iterations} remediation round(s)`;
    document.getElementById("scan-btn").disabled = false;
    // Remove approval card if somehow still present
    const inlineApproval = document.getElementById("approval-inline");
    if (inlineApproval) inlineApproval.remove();
    // Hide chat bar — user explicitly ended the session
    document.getElementById("chat-input-bar").style.display = "none";
    awaitingFollowup = false;
  }
  else if (msg.type === "awaiting_followup") {
    addSystemLine("⏸ " + msg.message);
    statusEl.textContent = "Awaiting follow-up";
    // Switch chat bar to follow-up mode
    awaitingFollowup = true;
    const ta = document.getElementById("chat-bar-input");
    ta.placeholder = "Ask a follow-up question, request re-investigation, or type \'done\' to finish";
    document.getElementById("chat-input-bar").style.display = "block";
    document.getElementById("chat-bar-send").disabled = false;
    ta.focus();
  }
  else if (msg.type === "followup_answer") {
    addChatBubble("llm", `FollowupAgent (${msg.decision})`, msg.answer);
    if (msg.decision === "reinvestigate") {
      addSystemLine("♻ Re-investigation starting…");
      awaitingFollowup = false;
    } else if (msg.decision === "remediate") {
      addSystemLine("🔧 Starting remediation phase…");
      awaitingFollowup = false;
    } else if (msg.decision === "done") {
      // Session is over — update UI immediately without waiting for type:"done".
      awaitingFollowup = false;
      document.getElementById("chat-input-bar").style.display = "none";
      document.getElementById("scan-btn").disabled = false;
      statusEl.textContent = "Done";
    }
    // For "answered" / "report", awaiting_followup will be set true again by the next awaiting_followup broadcast
  }
  else if (msg.type === "scan_report") {
    addResultTableInline(msg.vulnerability_status || {}, msg.cve_details || {});
    addSystemLine(`📋 Report updated — ${msg.check_iterations} check round(s) / ${msg.remediation_iterations} remediation round(s)`);
  }
  else if (msg.type === "error") {
    addChatBubble("system", "ERROR", msg.message);
    statusEl.textContent = "An error occurred";
    document.getElementById("scan-btn").disabled = false;
  }
}

function renderApprovalBox(msg) {
  // Remove previous inline approval card if any
  const old = document.getElementById("approval-inline");
  if (old) old.remove();

  const log = document.getElementById("chat-log");
  const label = msg.approval_type === "check"
    ? `Check Commands (Round ${msg.round})`
    : `Remediation Commands (Round ${msg.round})`;

  let checkboxes = msg.commands.map((cmd, i) =>
    `<div class="cmd-item">
       <input type="checkbox" id="cmd_${i}" value="${escHtml(cmd)}" checked>
       <label for="cmd_${i}"><code>${escHtml(cmd)}</code></label>
     </div>`
  ).join("");

  const wrap = document.createElement("div");
  wrap.id = "approval-inline";
  wrap.className = "approval-inline-card";
  wrap.innerHTML = `
    <div class="approval-box">
      <h3>${escHtml(label)}</h3>
      ${checkboxes}
      <div class="user-note-area">
        <label for="user-note-input">Message to AI (optional) — questions, context, or instructions for the next round:</label>
        <textarea id="user-note-input" rows="2" placeholder="e.g. Focus on whether the host is actually using WPA-Enterprise. Ignore consumer setups."></textarea>
        <div class="send-note-row">
          <button class="btn btn-send" onclick="sendNoteFromApproval()">Send message now</button>
        </div>
      </div>
      <div style="margin-top:0.8rem;display:flex;gap:0.5rem">
        <button class="btn btn-approve" onclick="submitApproval('${msg.approval_type}')">Approve &amp; Run</button>
        <button class="btn btn-skip"    onclick="skipApproval('${msg.approval_type}')">Skip</button>
      </div>
    </div>`;
  log.appendChild(wrap);
  log.scrollTop = log.scrollHeight;
}

function submitApproval(approvalType) {
  const checkboxes = document.querySelectorAll("#approval-inline input[type=checkbox]:checked");
  const commands = Array.from(checkboxes).map(cb => cb.value);
  const userNote = (document.getElementById("user-note-input")?.value || "").trim();
  sendApproval(approvalType, commands, userNote);
}

function skipApproval(approvalType) {
  const userNote = (document.getElementById("user-note-input")?.value || "").trim();
  sendApproval(approvalType, [], userNote);
}

function sendApproval(approvalType, commands, userNote) {
  // Remove the approval card and replace it with a user-bubble summary.
  const inlineBox = document.getElementById("approval-inline");
  if (inlineBox) {
    let summary;
    if (commands.length === 0) {
      summary = userNote ? `Skipped. Note: ${userNote}` : "Skipped all commands.";
    } else {
      const cmdList = commands.map(c => `  • ${c}`).join("\n");
      summary = userNote
        ? `Approved:\n${cmdList}\n\nNote: ${userNote}`
        : `Approved:\n${cmdList}`;
    }
    // Replace the approval card with a right-side user bubble.
    const bubble = document.createElement("div");
    bubble.className = "chat-msg agent";
    bubble.innerHTML = `<div class="chat-label">You</div><div class="chat-bubble">${escHtml(summary)}</div>`;
    inlineBox.replaceWith(bubble);
  }

  const body = new URLSearchParams({ approval_type: approvalType, user_note: userNote });
  commands.forEach(c => body.append("approved_commands[]", c));

  fetch(`/scans/${currentScanId}/approve`, {
    method: "POST",
    headers: {
      "Content-Type": "application/x-www-form-urlencoded",
      "X-CSRF-Token": document.querySelector("meta[name='csrf-token']")?.content || ""
    },
    body: body.toString()
  });
}

function addResultTableInline(vulnStatus, cveDetails) {
  // Find or create the LLM bubble that holds the results table.
  // It is rendered as a left-side (llm) bubble so it reads as CveAnalyst's answer.
  let container = document.getElementById("inline-results");
  if (!container) {
    const bubble = addChatBubble("llm", "CveAnalyst (assessment)", "");
    // Widen the bubble so the results table fits without truncation.
    bubble.parentElement.classList.add("wide");
    container = document.createElement("div");
    container.id = "inline-results";
    bubble.appendChild(container);
  }

  let rows = "";
  Object.entries(vulnStatus).forEach(([cveId, status]) => {
    const cls = status === "vulnerable" ? "vulnerable"
              : status === "not_vulnerable" ? "not_vulnerable"
              : status === "remediated" ? "remediated"
              : "unknown";
    const statusLabel = status === "vulnerable" ? "Vulnerable"
                      : status === "not_vulnerable" ? "Not Vulnerable"
                      : status === "remediated" ? "Remediated"
                      : status === "not_found" ? "CVE not found on Ubuntu tracker"
                      : status === "no_packages" ? "No Ubuntu packages affected"
                      : status;
    const d = cveDetails[cveId] || {};
    let detail = "";
    if (status === "not_found") {
      detail = `<div class="detail-reason">This CVE ID is not registered on the Ubuntu Security Tracker.</div>`;
    } else {
      if (d.description) detail += `<div class="detail-desc">${escHtml(d.description)}</div>`;
      if (d.packages && d.packages.length) detail += `<div class="detail-pkg">Packages: ${d.packages.map(escHtml).join(", ")}</div>`;
      if (d.reasoning) detail += `<div class="detail-reason">${escHtml(d.reasoning)}</div>`;
    }
    rows += `<tr><td>${escHtml(cveId)}</td><td class="${cls}">${statusLabel}</td><td>${detail}</td></tr>`;
  });

  container.innerHTML = `<table class="result-table"><thead><tr><th>CVE ID</th><th>Status</th><th>Details</th></tr></thead><tbody>${rows}</tbody></table>`;

  const log = document.getElementById("chat-log");
  log.scrollTop = log.scrollHeight;
}

// Send the note from the approval box WITHOUT approving/skipping
function sendNoteFromApproval() {
  const ta = document.getElementById("user-note-input");
  const text = (ta?.value || "").trim();
  if (!text) return;
  postNote(text);
  ta.value = "";
}

// Send a standalone note from the persistent chat bar
function sendStandaloneNote() {
  const ta = document.getElementById("chat-bar-input");
  const text = (ta?.value || "").trim();
  if (!text) return;
  if (awaitingFollowup) {
    // Route to the follow-up endpoint (resumes the StateGraph)
    addChatBubble("agent", "You", text);
    const btn = document.getElementById("chat-bar-send");
    btn.disabled = true;
    awaitingFollowup = false; // prevent double-send
    ta.value = "";
    postFollowup(text, () => { btn.disabled = false; });
  } else {
    const btn = document.getElementById("chat-bar-send");
    btn.disabled = true;
    postNote(text, () => { ta.value = ""; btn.disabled = false; });
  }
}

// POST note to the server (ActionCable will echo it back as user_note)
function postNote(text, callback) {
  fetch(`/scans/${currentScanId}/note`, {
    method: "POST",
    headers: {
      "Content-Type": "application/x-www-form-urlencoded",
      "X-CSRF-Token": document.querySelector("meta[name='csrf-token']")?.content || ""
    },
    body: new URLSearchParams({ note: text })
  }).finally(() => { if (callback) callback(); });
}

// POST follow-up message (resumes the StateGraph at :handle_followup)
function postFollowup(text, callback) {
  fetch(`/scans/${currentScanId}/followup`, {
    method: "POST",
    headers: {
      "Content-Type": "application/x-www-form-urlencoded",
      "X-CSRF-Token": document.querySelector("meta[name='csrf-token']")?.content || ""
    },
    body: new URLSearchParams({ message: text })
  }).finally(() => { if (callback) callback(); });
}

function escHtml(str) {
  return String(str)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}
